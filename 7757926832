local function runTouchScript()
    local r = (game.Players.LocalPlayer.Character or game.Players.LocalPlayer.CharacterAdded:Wait()):WaitForChild("HumanoidRootPart")
    for _, p in pairs(workspace:GetDescendants()) do
        if p.Name == "TouchPart" and p:IsA("BasePart") then
            firetouchinterest(r, p, 0)
            firetouchinterest(r, p, 1)
        end
    end
