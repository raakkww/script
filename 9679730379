-- [[ RoHub - Rocta ]]
-- Script Type: Auto Train Level
-- UI Library: Rayfield
-- Status: Key System Removed / Direct Access

-- 1. Load Rayfield Library
local Rayfield = loadstring(game:HttpGet("https://raw.githubusercontent.com/RayfieldUI/Rayfield/main/source"))()

-- 2. Create Main Window with Rebranding
local Window = Rayfield:CreateWindow({
   Name = "RoHub - Rocta",
   LoadingTitle = "RoHub - Rocta Suite",
   LoadingSubtitle = "by Rocta",
   Theme = "Dark",
   ColorScheme = {
      Main = Color3.fromRGB(25, 25, 25),
      Accent = Color3.fromRGB(0, 170, 255), -- Modern Cyan Blue
      Light = Color3.fromRGB(240, 240, 240),
      Dark = Color3.fromRGB(15, 15, 15),
      Text = Color3.fromRGB(255, 255, 255),
      TextDark = Color3.fromRGB(150, 150, 150)
   }
})

-- 3. Create Tab
local MainTab = Window:CreateTab("Auto Train", "rbxassetid://4483345998")

-- 4. Variables for Loop Control
local Enabled = false
local LoopConnection = nil

-- 5. Create Toggle Feature
MainTab:CreateToggle("Auto Level Up", function(state)
    Enabled = state
    if Enabled then
        print("[RoHub - Rocta] Auto Level Started")
        -- Spawn loop separately to prevent UI freezing
        LoopConnection = task.spawn(function()
            while Enabled do
                task.wait() -- Prevents spam filtering
                pcall(function()
                    local ReplicatedStorage = game:GetService("ReplicatedStorage")
                    local RemoteEvents = ReplicatedStorage:FindFirstChild("RemoteEvents")
                    if RemoteEvents then
                        local TrainLevel = RemoteEvents:FindFirstChild("TrainLevel")
                        if TrainLevel then
                            TrainLevel:FireServer()
                        end
                    end
                end)
            end
        end)
    else
        print("[RoHub - Rocta] Auto Level Stopped")
        -- Safely stop the loop
        if LoopConnection then
            task.cancel(LoopConnection)
            LoopConnection = nil
        end
    end
end)

-- 6. Load Notification
Rayfield:Notify({
   Title = "RoHub - Rocta",
   Content = "Script loaded successfully. No Key Required.",
   Duration = 5,
   Image = 4483345998
})

-- 7. Final Branding Print
print("[RoHub - Rocta] Initialized Successfully")
