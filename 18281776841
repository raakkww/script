-- [[ SPAWN LOGIC ]]
SpawnBtn.MouseButton1Click:Connect(function()
	if SelectedCar ~= "" then
		local fullName = SelectedCar .. " - Stock"
		SpawnRemote:FireServer(fullName)
		print("[RoHub - Rocta] Attempting to spawn: " .. fullName)
        
        -- Visual Feedback on Button
        local originalText = SpawnBtn.Text
        SpawnBtn.Text = "SPAWNED!"
        SpawnBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
        task.wait(0.5)
        SpawnBtn.Text = originalText
        SpawnBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
	else
		DropdownBtn.Text = "RoHub: PICK A CAR!"
        DropdownBtn.TextColor3 = Color3.fromRGB(255, 50, 50)
		task.wait(1)
		DropdownBtn.Text = "Select a Car..."
        DropdownBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	end
end)

