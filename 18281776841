-- [[ DROPDOWN LOGIC ]]
DropdownBtn.MouseButton1Click:Connect(function()
	ScrollFrame.Visible = not ScrollFrame.Visible
    -- Bring to front when opened
    if ScrollFrame.Visible then
        ScrollFrame.ZIndex = 10
        MainFrame.ZIndex = 5
    else
        ScrollFrame.ZIndex = 5
        MainFrame.ZIndex = 1
    end
end)

-- Generate Car List
for _, car in ipairs(cars) do
	local b = Instance.new("TextButton", ScrollFrame)
	b.Size = UDim2.new(1, -10, 0, 35)
	b.Position = UDim2.new(0, 5, 0, 0) -- Padding inside scroll
	b.Text = car.n .. " ($" .. tostring(car.p) .. ")"
	b.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
	b.TextColor3 = Color3.fromRGB(255, 255, 255)
	b.Font = Enum.Font.GothamMedium
	b.TextSize = 12
	b.ZIndex = 11
	
    local BtnCorner = Instance.new("UICorner", b)
    BtnCorner.CornerRadius = UDim.new(0, 4)
	
	b.MouseButton1Click:Connect(function()
		SelectedCar = car.n
		DropdownBtn.Text = car.n
        DropdownBtn.TextColor3 = Color3.fromRGB(0, 255, 255) -- Highlight selected
		ScrollFrame.Visible = false
	end)
    
    -- Hover Effect for List Items
    b.MouseEnter:Connect(function()
        b.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    end)
    b.MouseLeave:Connect(function()
        b.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    end)
end

